{"kind":"article","hierarchy":{"paths":[["doc:\/\/swiftonig.SwiftOnig\/documentation\/SwiftOnig"]]},"variants":[{"paths":["\/documentation\/swiftonig\/introduction"],"traits":[{"interfaceLanguage":"swift"}]}],"abstract":[{"text":"SwiftOnig is a modern, high-performance regular expression library for Swift, built as a wrapper around the powerful ","type":"text"},{"isActive":true,"identifier":"https:\/\/github.com\/kkos\/oniguruma","type":"reference"},{"text":" C library.","type":"text"}],"sections":[],"schemaVersion":{"minor":3,"major":0,"patch":0},"primaryContentSections":[{"kind":"content","content":[{"level":2,"type":"heading","text":"Overview","anchor":"Overview"},{"inlineContent":[{"type":"text","text":"While Swift provides built-in regular expression support, SwiftOnig offers several advantages for specialized use cases:"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"inlineContent":[{"text":"Comprehensive Encoding Support","type":"text"}],"type":"strong"},{"text":": Support for a wide range of character encodings beyond UTF-8 and UTF-16.","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Advanced Syntax Modes"}],"type":"strong"},{"text":": Support for Perl, Python, Java, Ruby, and many other regex syntaxes.","type":"text"}]}]},{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"Capture History"}],"type":"strong"},{"type":"text","text":": Access to the complete hierarchy of capture group matches."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Modern Swift Integration"}]},{"type":"text","text":": Full support for Swift Concurrency ("},{"type":"codeVoice","code":"async\/await"},{"type":"text","text":") and thread-safety ("},{"type":"codeVoice","code":"Sendable"},{"type":"text","text":")."}]}]}]},{"level":2,"type":"heading","text":"Key Concepts","